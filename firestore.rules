rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /transactions/{doc} {
      allow read: if request.auth != null && request.auth.token.dashboard == true;
      allow write: if false;
    }
    match /mrr_snapshots/{doc} {
      allow read: if request.auth != null && request.auth.token.dashboard == true;
      allow write: if false;
    }
    match /churn_cohorts/{doc} {
      allow read: if request.auth != null && request.auth.token.dashboard == true;
      allow write: if false;
    }
    match /refund_cohorts/{doc} {
      allow read: if request.auth != null && request.auth.token.dashboard == true;
      allow write: if false;
    }
    match /ad_spend/{doc} {
      allow read: if request.auth != null && request.auth.token.dashboard == true;
      allow write: if false;
    }
    match /roas_cohorts/{doc} {
      allow read: if request.auth != null && request.auth.token.dashboard == true;
      allow write: if false;
    }
  }
}
